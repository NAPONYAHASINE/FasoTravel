# Firebase configuration for FCM push notifications
# Copy this template to .env.local and fill in your Firebase credentials

# Firebase API Key (from Project Settings → General)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com

# Firebase Messaging Sender ID (from Cloud Messaging tab)
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID

# Firebase App ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# VAPID Key for push notifications (generate in Cloud Messaging → Web push certificates)
VITE_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY

# ============================================================
# HOW TO GET THESE VALUES:
# ============================================================
# 
# 1. Go to https://console.firebase.google.com
# 2. Select your FasoTravel project
# 3. Click ⚙️ (Settings) at the top left
# 4. Go to "Project Settings"
# 5. Click the "General" tab
# 6. Under "Your apps", find your Web app
# 7. Copy firebaseConfig object:
#
#    const firebaseConfig = {
#      apiKey: "...",                    ← VITE_FIREBASE_API_KEY
#      authDomain: "...",                ← VITE_FIREBASE_AUTH_DOMAIN
#      projectId: "...",                 ← VITE_FIREBASE_PROJECT_ID
#      storageBucket: "...",             ← VITE_FIREBASE_STORAGE_BUCKET
#      messagingSenderId: "...",         ← VITE_FIREBASE_MESSAGING_SENDER_ID
#      appId: "..."                      ← VITE_FIREBASE_APP_ID
#    };
#
# 8. For VAPID Key:
#    - Go to Messaging in left sidebar
#    - Under "Cloud Messaging" tab
#    - Scroll to "Web push certificates"
#    - Click "Generate new key pair"
#    - Copy the public key → VITE_FIREBASE_VAPID_KEY
#
# ============================================================
