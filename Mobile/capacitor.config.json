{
  "appId": "com.fasotravel.app",
  "appName": "FasoTravel",
  "webDir": "build",
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#ffffff"
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DARK",
