# ============================================
# FasoTravel Backend — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

NODE_ENV=development
PORT=3003
API_PREFIX=api

DB_HOST=localhost
DB_PORT=5432
DB_NAME=fasotravel
DB_USER=fasotravel
DB_PASSWORD=CHANGE_ME
DB_SYNCHRONIZE=true
DB_LOGGING=true

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=CHANGE_ME_256_BIT_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_256_BIT_RANDOM
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

INFOBIP_API_KEY=
INFOBIP_BASE_URL=

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=
AWS_CLOUDFRONT_URL=

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@fasotravel.com
